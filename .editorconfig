# EditorConfig — https://editorconfig.org
# Ensures consistent coding style across all editors and IDEs.

root = true

# ── Defaults (all files) ─────────────────────────────────────────────
[*]
charset            = utf-8
end_of_line        = lf
insert_final_newline  = true
trim_trailing_whitespace = true
indent_style       = space
indent_size        = 4

# ── Python ────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 120

# ── JavaScript / JSX / TypeScript ─────────────────────────────────────
[*.{js,jsx,ts,tsx}]
indent_size = 2

# ── CSS / SCSS ────────────────────────────────────────────────────────
[*.{css,scss}]
indent_size = 2

# ── HTML ──────────────────────────────────────────────────────────────
[*.html]
indent_size = 2

# ── JSON ──────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ── YAML ──────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false   # trailing spaces are significant in Markdown

# ── Makefiles ──────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
