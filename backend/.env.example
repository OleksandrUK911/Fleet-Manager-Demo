# .env.example — Copy this file to .env and fill in your values
# Never commit the actual .env file to Git (it's in .gitignore)

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development — no extra services required):
DATABASE_URL=sqlite:///./fleet.db

# MySQL (production — uncomment and fill in your credentials):
# DATABASE_URL=mysql+pymysql://fleet_user:fleet_pass@localhost:3306/fleet_manager

# ── JWT Authentication ───────────────────────────────────────────────────────
# Minimum 32 characters. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret-string-minimum-32-chars

# ── Application Settings ──────────────────────────────────────────────────────
APP_ENV=development         # development | production
APP_DEBUG=True              # Set to False in production

# ── CORS Allowed Origins ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://fleet-manager-demo.skakun-ml.com
