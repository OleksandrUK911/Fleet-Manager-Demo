# .gitignore — Files and folders to exclude from version control

# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
venv/
.venv/
env/
.env
*.egg-info/
dist/
build/
.pytest_cache/

# ── Node / React ──────────────────────────────────
node_modules/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE / Editor ──────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────
*.log
logs/

# ── Database ──────────────────────────────────────
*.db
*.sqlite
backend/fleet.db          # explicit: local SQLite dev database
ci_test.db                # created by pytest in GitHub Actions CI

# ── Website build ─────────────────────────────────
website/dist/
website/.env.local
